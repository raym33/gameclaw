PORT=3001

# Default behavior:
# - If AUTO_LOCAL_AI is not 0, Gameclaw will try local Ollama first.
# - If that fails, the server falls back to the built-in demo blueprint path.
AUTO_LOCAL_AI=1

# Option A: local Ollama on this machine or another Mac
# AI_PROVIDER=ollama
# AI_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=gemma3:4b
# AI_PROVIDER_LABEL=MacBook Ollama

# Option B: LM Studio on a Mac mini or any OpenAI-compatible endpoint
# AI_PROVIDER=lmstudio
# AI_BASE_URL=http://192.168.1.50:1234/v1
# AI_MODEL=qwen2.5-vl-7b-instruct
# AI_API_KEY=lm-studio
# AI_PROVIDER_LABEL=Mac mini LM Studio

# Legacy OpenAI-compatible envs are still accepted:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=
